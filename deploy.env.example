# Copy to deploy.env and fill in. Used by ./deploy.sh and docker compose.
# deploy.env is gitignored — keep your secrets out of version control.

# --- Ubicloud ---
export UBI_TOKEN=pat-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEPLOY_LOCATION=eu-central-h1
DEPLOY_NAME=r2proxy
DEPLOY_SIZE=standard-2

# --- upstream R2 target ---
R2PROXY_ENDPOINT=https://ACCOUNT.r2.cloudflarestorage.com
R2PROXY_ACCESS_KEY=your_r2_access_key_id
R2PROXY_SECRET_KEY=your_r2_secret_access_key
R2PROXY_REGION=auto

# --- admin ---
# Leave blank to auto-generate; set to pin a known global admin token.
R2PROXY_ADMIN_TOKEN=

# Restrict the admin console (port 8081) to your current public IP only.
# The data-plane proxy (8080) is always open (it is authenticated by SigV4).
LOCK_ADMIN_TO_MY_IP=true
